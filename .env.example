# Notion
# The root page ID from your publicly-shared Notion page URL
ROOT_PAGE_ID=37a3524f-4759-80e7-81ca-e4f252f03d74

# Domain (used for absolute URL generation)
PORTAL_DOMAIN=localhost:3000
# NEXT_PUBLIC_PORTAL_DOMAIN=timeleap.brokenegg.io   # set for client-side absolute URLs

# Auth (NextAuth v5)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Database (Neon Postgres for Vercel/production, local Postgres for dev)
# On Vercel: provision via Vercel Storage → Neon, then paste the connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Revalidation webhook secret
# POST /api/revalidate with { "secret": "<this value>", "slug": "optional-slug" }
REVALIDATE_SECRET=change-me

# Seed admin credentials (used by: npx tsx prisma/seed.ts)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me
